[Unit]
Description=scheduled-dev-agent — GitHub issue to PR automation
After=network.target
Documentation=https://github.com/gs97ahn/scheduled-dev-agent

[Service]
Type=simple
User=<REPLACE_WITH_OPERATOR_USER>
Group=<REPLACE_WITH_OPERATOR_GROUP>
WorkingDirectory=/srv/scheduled-dev-agent
EnvironmentFile=/etc/scheduled-dev-agent/.env
ExecStart=/usr/local/bin/scheduled-dev-agent -config /etc/scheduled-dev-agent/config.yaml
Restart=on-failure
RestartSec=5s

# Ensure child claude processes are killed on stop
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=30s

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/srv/scheduled-dev-agent/data
ReadWritePaths=/srv/scheduled-dev-agent/.worktrees

[Install]
WantedBy=multi-user.target
