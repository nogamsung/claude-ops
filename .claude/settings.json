{
  "enabledPlugins": {
    "zoom-plugin@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "marketing-skills@marketingskills": true
  },
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(golangci-lint *)",
      "Bash(migrate *)",
      "Bash(mockery *)",
      "Bash(swag *)",
      "Bash(sqlc *)",
      "Bash(git *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(docker compose *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "bash .claude/hooks/session-start.sh" }] }
    ],
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "bash .claude/hooks/safety-guard.sh" }] },
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "bash .claude/hooks/pre-push.sh" }] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write|MultiEdit", "hooks": [{ "type": "command", "command": "bash .claude/hooks/post-edit-lint.sh" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "if [ -f go.mod ]; then echo \"[Harness] go vet\"; go vet ./... 2>&1 | tail -20; fi" }] }
    ]
  }
}
